# Database (required)
DATABASE_URL=postgresql://user:password@host:port/database

# Supabase (required for auth and optional storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (required for automation links, e.g. booking URL in WhatsApp reminders)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Email (Resend) — optional, for appointment notifications to staff
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=Clinic OS <notifications@your-domain.com>

# Optional: Dev bypass for API tests
# TEST_AUTH_BYPASS=true
